<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <div class="flex items-start justify-between gap-4">
    <div>
      <a href="/events/<%= event.id %>" class="text-sm text-slate-500 hover:text-slate-700 mb-2 inline-block">← Back to Event</a>
      <h1 class="text-3xl font-bold text-slate-900 mb-2">Attendee List</h1>
      <p class="text-slate-700"><%= event.title %></p>
    </div>
  </div>
</section>

<%
  const sections = [
    { key: "attending", title: "Attending", items: attendeeGroups.attending },
    { key: "waitlisted", title: "Waitlisted", items: attendeeGroups.waitlisted },
    { key: "cancelled", title: "Cancelled", items: attendeeGroups.cancelled },
  ];
%>

<section class="max-w-4xl grid gap-5">
  <% sections.forEach((section) => { %>
    <article class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-slate-900"><%= section.title %></h2>
        <span class="text-sm text-slate-500"><%= section.items.length %> RSVP(s)</span>
      </div>

      <% if (section.items.length === 0) { %>
        <p class="text-slate-500 text-sm">No attendees in this section yet.</p>
      <% } else { %>
        <ul class="divide-y divide-slate-200">
          <% section.items.forEach((attendee) => { %>
            <li class="py-3 flex items-center justify-between gap-3">
              <span class="font-medium text-slate-900"><%= attendee.displayName %></span>
              <time class="text-sm text-slate-500"><%= new Date(attendee.rsvpedAt).toLocaleString() %></time>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </article>
  <% }) %>
</section>
