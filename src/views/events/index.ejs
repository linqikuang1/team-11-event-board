<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <div class="flex items-center justify-between gap-4 mb-3">
    <h1 class="text-3xl font-bold text-slate-900">Upcoming Events</h1>
    <% if (session.authenticatedUser?.role === "staff" || session.authenticatedUser?.role === "admin") { %>
      <a href="/events/create" class="px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700">Create Event</a>
    <% } %>
  </div>
  <form>
    <input
      type="search"
      name="q"
      value="<%= query %>"
      placeholder="Search by title, description, or location"
      hx-get="/events/search"
      hx-trigger="input changed delay:400ms, search"
      hx-target="#event-list"
      hx-swap="innerHTML"
      class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
    />
  </form>
</section>

<% if (typeof successMessage !== 'undefined' && successMessage) { %>
  <div class="mb-4 p-4 border border-green-200 rounded-2xl bg-green-50 text-green-700 text-sm font-medium">
    <%= successMessage %>
  </div>
<% } %>

<% if (pageError) { %>
  <%- include("../partials/error", { message: pageError }) %>
<% } %>

<section class="max-w-3xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <div id="event-list">
    <%- include("../partials/list", { events: events }) %>
  </div>
</section>