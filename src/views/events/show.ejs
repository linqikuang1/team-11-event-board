<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-slate-900 mb-2"><%= event.title %></h1>
      <span class="inline-block px-3 py-1 rounded-full text-sm font-medium
        <%= event.status === 'published' ? 'bg-green-100 text-green-700' :
            event.status === 'draft' ? 'bg-yellow-100 text-yellow-700' :
            event.status === 'cancelled' ? 'bg-red-100 text-red-700' :
            'bg-slate-100 text-slate-600' %>">
        <%= event.status.charAt(0).toUpperCase() + event.status.slice(1) %>
      </span>
    </div>

    <% if (session.authenticatedUser?.role === "staff" || session.authenticatedUser?.role === "admin") { %>
      <div class="flex gap-2 flex-shrink-0">
        <% if (event.status === "draft" || event.status === "published") { %>
            <a href="/events/<%= event.id %>/edit" class="px-4 py-2 rounded-lg border border-slate-300 text-slate-600 text-sm font-medium hover:bg-slate-50">Edit</a>
        <% } %>
        <% if (event.status === "draft") { %>
          <form method="post" action="/events/<%= event.id %>/publish">
            <button
              type="submit"
              class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700"
            >
              Publish
            </button>
          </form>
        <% } %>
        <% if (event.status === "published") { %>
          <form method="post" action="/events/<%= event.id %>/cancel">
            <button
              type="submit"
              class="px-4 py-2 rounded-lg bg-red-600 text-white text-sm font-medium hover:bg-red-700"
            >
              Cancel Event
            </button>
          </form>
        <% } %>
      </div>
    <% } %>
  </div>
</section>

<section class="max-w-3xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <div class="grid gap-5">

    <% if (event.description) { %>
      <div>
        <h2 class="text-sm font-medium text-slate-500 mb-1">Description</h2>
        <p class="text-slate-800"><%= event.description %></p>
      </div>
    <% } %>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <h2 class="text-sm font-medium text-slate-500 mb-1">Location</h2>
        <p class="text-slate-800"><%= event.location %></p>
      </div>
      <div>
        <h2 class="text-sm font-medium text-slate-500 mb-1">Capacity</h2>
        <p class="text-slate-800"><%= event.capacity ?? "Unlimited" %></p>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <h2 class="text-sm font-medium text-slate-500 mb-1">Start Time</h2>
        <p class="text-slate-800"><%= new Date(event.startTime).toLocaleString() %></p>
      </div>
      <div>
        <h2 class="text-sm font-medium text-slate-500 mb-1">End Time</h2>
        <p class="text-slate-800"><%= new Date(event.endTime).toLocaleString() %></p>
      </div>
    </div>

    <% if (event.tags.length > 0) { %>
      <div>
        <h2 class="text-sm font-medium text-slate-500 mb-2">Tags</h2>
        <div class="flex flex-wrap gap-2">
          <% event.tags.forEach(tag => { %>
            <span class="px-2 py-1 bg-slate-100 text-slate-600 text-sm rounded-lg"><%= tag %></span>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (session.authenticatedUser?.role === "user") { %>
      <div class="pt-4 border-t border-slate-200">
        <form method="post" action="/events/<%= event.id %>/rsvp">
          <button
            type="submit"
            class="px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700"
          >
            RSVP to this event
          </button>
        </form>
      </div>
    <% } %>

  </div>
</section>