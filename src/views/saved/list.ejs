<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <div class="flex items-center justify-between gap-4">
    <h1 class="text-3xl font-bold text-slate-900">Saved Events</h1>
    <a href="/events" class="text-sm text-slate-500 hover:text-slate-700">← Back to Events</a>
  </div>
</section>

<section class="max-w-3xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <% if (entries.length === 0) { %>
    <p class="text-slate-400 italic">You haven't saved any events yet.</p>
  <% } else { %>
    <div class="grid gap-4">
      <% entries.forEach(function(entry) { %>
        <div class="p-4 border border-slate-200 rounded-xl bg-slate-50 flex items-start justify-between gap-4">
          <div class="min-w-0">
            <a href="/events/<%= entry.event.id %>" class="text-lg font-semibold text-slate-900 hover:text-blue-600">
              <%= entry.event.title %>
            </a>
            <div class="flex flex-wrap items-center gap-3 mt-1 text-sm text-slate-500">
              <span><%= entry.event.location %></span>
              <span>&middot;</span>
              <span><%= new Date(entry.event.startTime).toLocaleString() %></span>
              <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium
                <%= entry.event.status === 'published' ? 'bg-green-100 text-green-700' :
                    entry.event.status === 'draft' ? 'bg-yellow-100 text-yellow-700' :
                    entry.event.status === 'cancelled' ? 'bg-red-100 text-red-700' :
                    'bg-slate-100 text-slate-600' %>">
                <%= entry.event.status.charAt(0).toUpperCase() + entry.event.status.slice(1) %>
              </span>
            </div>
            <p class="text-xs text-slate-400 mt-1">Saved on <%= new Date(entry.savedEvent.savedAt).toLocaleString() %></p>
          </div>
          <form method="post" action="/events/<%= entry.event.id %>/save" class="flex-shrink-0">
            <button
              type="submit"
              class="px-3 py-1.5 rounded-lg border border-red-200 text-red-600 text-sm font-medium hover:bg-red-50"
            >
              Unsave
            </button>
          </form>
        </div>
      <% }); %>
    </div>
  <% } %>
</section>
